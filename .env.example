# ─────────────────────────────────────────────────────────────────────────────
# go-server-monitor — environment template (P0 skeleton).
#
# Copy this file to `.env` and fill in the secrets:  cp .env.example .env
# `.env` is gitignored. docker-compose auto-loads it; the Go binary loads it
# via godotenv on startup.
#
# Authority: requirements/14-resolved-decisions.md (REQ-RES-01 settings keys),
#            requirements/12-build-plan.md (P0 deliverable 3, config keys).
#
# Bootstrap rule (REQ-RES-01/05): the SECRET / CREDENTIAL keys below are read
# from this file on FIRST start, hashed/stored into the SQLite `settings`
# table, and the DB becomes authoritative afterwards. Non-secret runtime
# settings (site title, theme, notifications, etc.) live in the DB and are
# edited via the admin UI (POST /api/admin/settings) — they are NOT here.
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret the probe sends (plaintext `secret` field in the POST /report
# JSON body; the server compares it constant-time against api_secret — no HMAC,
# HTTPS provides confidentiality). REQUIRED. Generate: openssl rand -base64 32
API_SECRET=

# Admin account bootstrap. Username defaults to `admin`. The password is
# bcrypt-hashed into settings.admin_password_hash on first start; you can then
# remove the plaintext from this file and change it via the admin UI.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# JWT signing secret (HS256, 7-day admin tokens). Leave blank to have the
# server generate a random one on first start. If set, use >=32 bytes.
# Generate: openssl rand -base64 32
JWT_SECRET=

# SQLite database file path. Host/dev default below; inside the container
# docker-compose overrides this to /data/metrics.db (a mounted volume).
DB_PATH=./data/metrics.db

# HTTP listen address for the Go server.
LISTEN_ADDR=:8080

# Comma-separated CORS allowed origins. Empty = same-origin only
# (do NOT use `*` in production). e.g. https://monitor.example.com
CORS_ORIGINS=

# History retention in days. Nightly cron deletes samples older than this.
# REQ-RES-08: on small disks (<20GB) prefer 30-90 days. Default 180.
REPORT_RETENTION_DAYS=180

# Timezone for alert-message / log rendering. Storage is always UTC/Unix seconds.
TZ=UTC

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ── Optional / deployment-only (not part of REQ-RES-01 bootstrap) ────────────

# Public domain for Caddy automatic HTTPS. Leave as localhost for local runs;
# set to your real hostname to get a Let's Encrypt certificate.
DOMAIN=localhost

# Constrain the Go heap on small VPS (REQ-OPS-06). TODO(P8): tune per host.
GOMEMLIMIT=200MiB
