# ─────────────────────────────────────────────────────────────────────────────
# go-server-monitor — Caddy: automatic HTTPS + reverse proxy (P8).
#
# Authority: requirements/10-deployment-ops.md (REQ-OPS-03),
#            requirements/12-build-plan.md (P8 REQ-DEPLOY-04).
#
# The Go binary is built with `-tags embed` (see Dockerfile) so it serves BOTH
# the API and the embedded Vue SPA. Caddy therefore only needs to terminate TLS
# and reverse-proxy everything to the app — no file_server / static root.
#
# Upstream `app:8080` is the Compose service name. Running Caddy outside compose
# (host Caddy in front of a host-run binary)? change it to `localhost:8080`.
# ─────────────────────────────────────────────────────────────────────────────

{
	# Structured access/error logs to stdout for container log aggregation.
	log {
		output stdout
		format json
	}
	# auto_https is on by default: set DOMAIN to a real hostname (compose passes
	# it in) and Caddy obtains + renews a Let's Encrypt certificate automatically.
}

# Site address. {$DOMAIN:localhost} → uses $DOMAIN env, defaults to localhost
# (Caddy serves a local self-signed cert for localhost).
{$DOMAIN:localhost} {
	encode gzip zstd

	# Everything — SPA, REST API, probe upload, WebSocket, health — is served by
	# the Go app, which embeds the SPA.
	reverse_proxy app:8080 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		# Long-lived /ws connections (coder/websocket upgrade is transparent).
		transport http {
			read_timeout 120s
			write_timeout 120s
		}
	}
}
