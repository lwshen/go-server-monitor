# ─────────────────────────────────────────────────────────────────────────────
# go-server-monitor PROBE (agent) — environment template.
#
# The probe is a separate binary from the server, meant to run on each monitored
# host. Provide these via the environment, e.g.:
#
#   SERVER_URL=https://monitor.example.com SERVER_ID=<uuid> API_SECRET=<secret> ./bin/probe
#
# or copy this file to `.env` on the probe host (auto-loaded via godotenv).
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the monitoring server to report to. REQUIRED.
SERVER_URL=http://localhost:8080

# This host's server id — a UUID created in the admin API beforehand:
#   curl -X POST $SERVER_URL/api/admin/servers/add -d '{"name":"my-host"}'
# The response's "id" goes here. REQUIRED (an unregistered id is rejected 404).
SERVER_ID=

# Shared upload secret; must equal the server's API_SECRET. REQUIRED.
API_SECRET=

# Sample (collect) interval in seconds. Default 5.
COLLECT_INTERVAL=5

# Upload (report) interval in seconds. Default 60. When larger than
# COLLECT_INTERVAL, one upload batches all samples collected since the last one.
REPORT_INTERVAL=60

# In-memory ring-buffer capacity (samples retained while the server is
# unreachable; oldest dropped when full). Default 300.
BUFFER_SIZE=300
